    {
      "id": "CVE-2024-10977",
      "source": "postgresql",
      "title": "PostgreSQL libpq retains an error message from man-in-the-middle",
      "description": "Client use of server error message in PostgreSQL allows a server not trusted\nunder current SSL or GSS settings to furnish arbitrary non-NUL bytes to the\nlibpq application. For example, a man-in-the-middle attacker could send a long\nerror message that a human or screen-scraper user of psql mistakes for valid\nquery results. This is probably not a concern for clients where the user\ninterface unambiguously indicates the boundary between one error message and\nother text. Versions before PostgreSQL 17",
      "severity": "low",
      "cvss_score": 3.1,
      "cvss_vector": null,
      "published_date": "2024-11-14",
      "modified_date": "",
      "affected": [],
      "references": [
        "https://www.postgresql.org/support/security/CVE-2024-10977/"
      ]
    },
    {
      "id": "CVE-2024-10978",
      "source": "postgresql",
      "title": "PostgreSQL SET ROLE, SET SESSION AUTHORIZATION reset to wrong user ID",
      "description": "Incorrect privilege assignment in PostgreSQL allows a less-privileged\napplication user to view or change different rows from those intended. An attack\nrequires the application to use\nSET ROLE\n,\nSET SESSION AUTHORIZATION\n,\nor an equivalent feature. The problem arises when an application query uses\nparameters from the attacker or conveys query results to the attacker. If that\nquery reacts to\ncurrent_setting('role')\nor the current user ID, it may modify\nor return data as though the session had not ",
      "severity": "medium",
      "cvss_score": 4.2,
      "cvss_vector": null,
      "published_date": "2024-11-14",
      "modified_date": "",
      "affected": [],
      "references": [
        "https://www.postgresql.org/support/security/CVE-2024-10978/"
      ]
    },
    {
      "id": "CVE-2024-10979",
      "source": "postgresql",
      "title": "PostgreSQL PL/Perl environment variable changes execute arbitrary code",
      "description": "Incorrect control of environment variables in PostgreSQL\nPL/Perl\nallows an\nunprivileged database user to change sensitive process environment variables\n(e.g.\nPATH\n). That often suffices to enable arbitrary code execution, even if\nthe attacker lacks a database server operating system user. Versions before\nPostgreSQL 17.1, 16.5, 15.9, 14.14, 13.17, and 12.21 are affected.",
      "severity": "high",
      "cvss_score": 8.8,
      "cvss_vector": null,
