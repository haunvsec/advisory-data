      ]
    },
    {
      "id": "CVE-2026-2005",
      "source": "postgresql",
      "title": "PostgreSQL",
      "description": "Heap buffer overflow in PostgreSQL\npgcrypto\nallows a ciphertext provider to\nexecute arbitrary code as the operating system user running the database.\nVersions before PostgreSQL 18.2, 17.8, 16.12, 15.16, and 14.21 are affected.",
      "severity": "high",
      "cvss_score": 8.8,
      "cvss_vector": null,
