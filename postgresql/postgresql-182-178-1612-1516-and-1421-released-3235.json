      ]
    },
    {
      "id": "CVE-2026-2006",
      "source": "postgresql",
      "title": "PostgreSQL missing validation of multibyte character length executes arbitrary code",
      "description": "Missing validation of multibyte character length in PostgreSQL text manipulation\nallows a database user to issue crafted queries that achieve a buffer overrun.\nThat suffices to execute arbitrary code as the operating system user running the\ndatabase.  Versions before PostgreSQL 18.2, 17.8, 16.12, 15.16, and 14.21 are\naffected.",
      "severity": "high",
      "cvss_score": 8.8,
      "cvss_vector": null,
      "published_date": "2026-02-12",
      "modified_date": "",
      "affected": [],
      "references": [
        "https://www.postgresql.org/support/security/CVE-2026-2006/"
      ]
    },
    {
      "id": "CVE-2026-2007",
      "source": "postgresql",
      "title": "PostgreSQL",
      "description": "Heap buffer overflow in PostgreSQL\npg_trgm\nallows a database user to achieve\nunknown impacts via a crafted input string.  The attacker has limited control\nover the byte patterns to be written, but we have not ruled out the viability of\nattacks that lead to privilege escalation.  PostgreSQL 18.1 and 18.0 are affected.",
      "severity": "high",
      "cvss_score": 8.2,
