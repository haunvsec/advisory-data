      "id": "CVE-2026-2003",
      "source": "postgresql",
      "title": "PostgreSQL",
      "description": "Improper validation of type\noidvector\nin PostgreSQL allows a database user to\ndisclose a few bytes of server memory. We have not ruled out viability of\nattacks that arrange for presence of confidential information in disclosed\nbytes, but they seem unlikely. Versions before PostgreSQL 18.2, 17.8, 16.12,\n15.16, and 14.21 are affected.",
      "severity": "medium",
      "cvss_score": 4.3,
      "cvss_vector": null,
      "published_date": "2026-02-12",
      "modified_date": "",
      "affected": [],
      "references": [
        "https://www.postgresql.org/support/security/CVE-2026-2003/"
      ]
    },
    {
      "id": "CVE-2026-2004",
      "source": "postgresql",
      "title": "PostgreSQL",
      "description": "Missing validation of type of input in PostgreSQL\nintarray\nextension\nselectivity estimator function allows an object creator to execute arbitrary\ncode as the operating system user running the database. Versions before\nPostgreSQL 18.2, 17.8, 16.12, 15.16, and 14.21 are affected.",
      "severity": "high",
      "cvss_score": 8.8,
      "cvss_vector": null,
      "published_date": "2026-02-12",
      "modified_date": "",
      "affected": [],
      "references": [
