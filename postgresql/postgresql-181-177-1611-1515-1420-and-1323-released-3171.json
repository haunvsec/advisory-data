      ]
    },
    {
      "id": "CVE-2025-12818",
      "source": "postgresql",
      "title": "PostgreSQL libpq undersizes allocations, via integer wraparound",
      "description": "Integer wraparound in multiple PostgreSQL\nlibpq\nclient library functions allows an application input provider or network peer to\ncause libpq to undersize an allocation and write out-of-bounds by hundreds of\nmegabytes.  This results in a segmentation fault for the application using\nlibpq. Versions before PostgreSQL 18.1, 17.7, 16.11, 15.15, 14.20, and 13.23 are\naffected.",
      "severity": "medium",
      "cvss_score": 5.9,
      "cvss_vector": null,
