    {
      "id": "CVE-2025-20383",
      "source": "splunk",
      "title": "Improper access control through push notifications for reports and alerts in Splunk Secure Gateway app",
      "description": "In Splunk Enterprise versions below 10.0.2, 9.4.6, 9.3.8, and 9.2.10, and below 3.9.10, 3.8.58, and 3.7.28 of Splunk Secure Gateway app in Splunk Cloud Platform, a low-privileged user that does not hold the \"admin\" or \"power\" Splunk roles and subscribes to mobile push notifications could receive notifications that disclose the title and description of the report or alert even if they do not have access to view the report or alert.",
      "severity": "medium",
